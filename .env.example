# Server port (default: 3003)
PORT=3003

# Absolute path to the markdown file to open on startup (optional).
# If not set, the app shows the landing page and lets you browse/open a file.
# DATA_FILE=/path/to/your/file.md

# ── AI writing assistant ─────────────────────────────────────────────────────
# The chat widget is hidden when ANTHROPIC_API_KEY is not set.
#
# Option A — Direct Anthropic API
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B — Databricks (or other OpenAI-compatible proxy)
# ANTHROPIC_BASE_URL=https://your-workspace.cloud.databricks.com/serving-endpoints/your-endpoint-name
# ANTHROPIC_API_KEY=dapi...
# ANTHROPIC_MODEL=databricks-claude-sonnet-4-6
